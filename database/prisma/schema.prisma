  ACTIVE
  PENDING_VERIFICATION
  SUSPENDED
  BANNED
  DELETED
}

enum LessonStatus {
  LOCKED
  AVAILABLE
  IN_PROGRESS
  COMPLETED
}

enum ActivityType {
  VOCABULARY
  MULTIPLE_CHOICE
  TRUE_FALSE
  MATCHING
  FILL_IN_BLANKS
  DRAG_DROP
  READING
