generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                         String                   @id @default(uuid()) @db.Uuid
  fullName                   String
  englishName                String?
  email                      String?                  @unique
  mobileNumber               String?                  @unique
  parentMobile               String?
  passwordHash               String?
  googleId                   String?                  @unique
  appleId                    String?                  @unique
  oauthProvider              String?
  role                       UserRole
  status                     AccountStatus            @default(PENDING_VERIFICATION)
  educationalSystem          String?
  educationalStage           String?
  grade                      String?
  academicTerm               String?
  governorate                String?
  school                     String?
  academicYearId             String?                  @db.Uuid
  termId                     String?                  @db.Uuid
  gradeId                    String?                  @db.Uuid
  createdAt                  DateTime                 @default(now())
  updatedAt                  DateTime                 @updatedAt
  deletedAt                  DateTime?
  activityProgress           ActivityProgress[]
  attendance                 AttendanceRecord[]
  coinWallet                 CoinWallet?
  conversations              Conversation[]
  lessonProgress             LessonProgress[]
  loginHistory               LoginHistory[]
  notificationPreferences    NotificationPreference?
  notifications              Notification[]
  passwordResets             PasswordReset[]
  payments                   Payment[]
  quizAttempts               QuizAttempt[]
  refreshTokens              RefreshToken[]
  sessions                   Session[]
  homeworkAttempts           StudentHomeworkAttempt[]
  achievements               UserAchievement[]
  videoProgress              VideoProgress[]
  xpTransactions             XPTransaction[]
  academicYear               AcademicYear?            @relation(fields: [academicYearId], references: [id])
  term                       Term?                    @relation(fields: [termId], references: [id])
  assignedGrade              Grade?                   @relation(fields: [gradeId], references: [id])
  teacherGrades              TeacherGrade[]
  auditLogs                  AuditLog[]
  managedByTeacherId         String?                  @db.Uuid
  managedByTeacher           User?                    @relation("TeacherManagesStaff", fields: [managedByTeacherId], references: [id])
  managedStaff               User[]                   @relation("TeacherManagesStaff")
  permissionGrants           UserPermissionGrant[]    @relation("PermissionHolder")
  grantedPermissions         UserPermissionGrant[]    @relation("PermissionGrantor")
  permissionsInitialized     Boolean                  @default(false)
  avatarUrl                  String?
  jobTitle                   String?
  liveSessionsAsTeacher      LiveSession[]            @relation("LiveSessionsAsTeacher")
  liveBookings               LiveBooking[]            @relation("LiveBookingStudent")
  liveAttendanceRecords      LiveAttendance[]         @relation("LiveAttendanceStudent")
  liveAttendanceMarked       LiveAttendance[]         @relation("LiveAttendanceMarker")
  liveSubscriptions          LiveSubscription[]       @relation("LiveSubscriptionHolder")
  liveSubscriptionsAsTeacher LiveSubscription[]       @relation("LiveSubscriptionTeacher")
  teacherAvailabilities      TeacherAvailability[]    @relation("TeacherAvailabilityTeacher")
  teacherDateBlocks          TeacherDateBlock[]       @relation("TeacherDateBlockTeacher")
  teacherLiveSettings        TeacherLiveSettings?
  liveAnnouncements          LiveAnnouncement[]       @relation("LiveAnnouncementSender")
  liveSessionControlLogs     LiveSessionControlLog[]  @relation("LiveSessionControlActor")
  assessmentAttempts         AssessmentAttempt[]
  coinPurchases              CoinPurchase[]
  miniExams                  MiniExam[]                  @relation("MiniExamUser")
  competitionsCreated        Competition[]               @relation("CompetitionCreator")
  competitionParticipations  CompetitionParticipant[]    @relation("CompetitionParticipantStudent")
  codesCreated               UnlockCode[]               @relation("UnlockCodeCreator")
  codeRedemptions            CodeRedemption[]
  contentUnlocks             ContentUnlock[]
  unlockRequests             UnlockRequest[]            @relation("UnlockRequestRequester")
  resolvedUnlockRequests     UnlockRequest[]            @relation("UnlockRequestResolver")
  storyAttempts               StoryAttempt[]             @relation("StoryAttemptUser")
  supportTicketsCreated       SupportTicket[]             @relation("SupportTicketCreator")
  supportTicketsAssigned      SupportTicket[]             @relation("SupportTicketAgent")
  supportMessages             SupportMessage[]            @relation("SupportMessageSender")

  @@index([mobileNumber])
  @@index([role])
  @@index([status])
  @@index([managedByTeacherId])
  @@map("users")
}

model Session {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @db.Uuid
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([token])
  @@map("sessions")
}

model RefreshToken {
  id        String    @id @default(uuid()) @db.Uuid
  userId    String    @db.Uuid
  token     String    @unique
  expiresAt DateTime
  createdAt DateTime  @default(now())
  revokedAt DateTime?
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([token])
  @@map("refresh_tokens")
}

model LoginHistory {
  id            String   @id @default(uuid()) @db.Uuid
  userId        String   @db.Uuid
  ipAddress     String?
  userAgent     String?
  success       Boolean
  failureReason String?
  createdAt     DateTime @default(now())
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([createdAt])
  @@map("login_history")
}

model PasswordReset {
  id               String    @id @default(uuid()) @db.Uuid
  userId           String    @db.Uuid
  verificationCode String
  expiresAt        DateTime
  usedAt           DateTime?
  createdAt        DateTime  @default(now())
  user             User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([verificationCode])
  @@map("password_resets")
}

model XPTransaction {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @db.Uuid
  amount    Int
  reason    String
  reference String?
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([createdAt])
  @@map("xp_transactions")
}

model CoinWallet {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @unique @db.Uuid
  balance   Int      @default(0)
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("coin_wallets")
}

model Payment {
  id              String    @id @default(uuid()) @db.Uuid
  userId          String    @db.Uuid
  productType     String
  productId       String
  amount          Int
  currency        String    @default("EGP")
  paymentMethod   String
  status          String    @default("PENDING")
  gatewayRef      String?
  gatewayResponse String?
  couponId        String?
  discount        Int       @default(0)
  createdAt       DateTime  @default(now())
  completedAt     DateTime?
  invoice         Invoice?
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([status])
  @@index([createdAt])
  @@map("payments")
}

model Invoice {
  id        String   @id @default(uuid()) @db.Uuid
  paymentId String   @unique @db.Uuid
  number    String   @unique
  createdAt DateTime @default(now())
  payment   Payment  @relation(fields: [paymentId], references: [id], onDelete: Cascade)

  @@map("invoices")
}

model Coupon {
  id                 String    @id @default(uuid()) @db.Uuid
  code               String    @unique
  discountType       String    @default("PERCENTAGE")
  discountValue      Int
  maxUses            Int?
  usedCount          Int       @default(0)
  expiresAt          DateTime?
  applicableProducts String?
  active             Boolean   @default(true)
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  @@map("coupons")
}

model CoinPackage {
  id          String   @id @default(uuid()) @db.Uuid
  name        String
  description String?
  coinAmount  Int
  price       Int
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  purchases   CoinPurchase[]

  @@map("coin_packages")
}

model CoinPurchase {
  id          String   @id @default(uuid()) @db.Uuid
  userId      String   @db.Uuid
  packageId   String   @db.Uuid
  coinAmount  Int
  price       Int
  paymentId   String?  @db.Uuid
  status      String   @default("COMPLETED")
  createdAt   DateTime @default(now())
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  package     CoinPackage @relation(fields: [packageId], references: [id])

  @@index([userId])
  @@map("coin_purchases")
}

model UnlockCode {
  id          String      @id @default(uuid()) @db.Uuid
  code        String      @unique
  coinAmount  Int
  maxUses     Int?
  usedCount   Int         @default(0)
  active      Boolean     @default(true)
  expiresAt   DateTime?
  createdById String      @db.Uuid
  createdBy   User        @relation("UnlockCodeCreator", fields: [createdById], references: [id])
  createdAt   DateTime    @default(now())

  redemptions CodeRedemption[]

  @@index([code])
  @@map("unlock_codes")
}

model CodeRedemption {
  id         String      @id @default(uuid()) @db.Uuid
  codeId     String      @db.Uuid
  userId     String      @db.Uuid
  coinAmount Int
  redeemedAt DateTime    @default(now())
  code       UnlockCode  @relation(fields: [codeId], references: [id])
  user       User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([codeId, userId])
  @@index([userId])
  @@map("code_redemptions")
}

model ContentUnlock {
  id           String   @id @default(uuid()) @db.Uuid
  userId       String   @db.Uuid
  targetType   String
  targetId     String   @db.Uuid
  unlockMethod String
  coinAmount   Int?
  createdAt    DateTime @default(now())
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, targetType, targetId])
  @@index([userId])
  @@index([targetType, targetId])
  @@map("content_unlocks")
}

model UnlockRequest {
  id            String    @id @default(uuid()) @db.Uuid
  userId        String    @db.Uuid
  targetType    String
  targetId      String    @db.Uuid
  status        String    @default("PENDING")
  adminNote     String?
  resolvedById  String?   @db.Uuid
  resolvedAt    DateTime?
  createdAt     DateTime  @default(now())
  user          User      @relation("UnlockRequestRequester", fields: [userId], references: [id], onDelete: Cascade)
  resolvedBy    User?     @relation("UnlockRequestResolver", fields: [resolvedById], references: [id])

  @@index([userId])
  @@index([status])
  @@map("unlock_requests")
}

model UserAchievement {
  id          String   @id @default(uuid()) @db.Uuid
  userId      String   @db.Uuid
  type        String
  title       String
  description String?
  icon        String?
  earnedAt    DateTime @default(now())
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, type])
  @@index([userId])
  @@map("user_achievements")
}

model LessonProgress {
  id          String    @id @default(uuid()) @db.Uuid
  userId      String    @db.Uuid
  lessonId    String    @db.Uuid
  completed   Boolean   @default(false)
  progress    Float     @default(0)
  startedAt   DateTime  @default(now())
  completedAt DateTime?
  lesson      Lesson    @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, lessonId])
  @@index([userId])
  @@index([lessonId])
  @@map("lesson_progress")
}

model AttendanceRecord {
  id      String   @id @default(uuid()) @db.Uuid
  userId  String   @db.Uuid
  date    DateTime @default(now())
  present Boolean  @default(true)
  user    User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, date])
  @@index([userId])
  @@index([date])
  @@map("attendance_records")
}

model Stage {
  id           String   @id @default(uuid()) @db.Uuid
  name         String
  displayOrder Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  grades       Grade[]

  @@index([displayOrder])
  @@map("stages")
}

model Grade {
  id                    String                @id @default(uuid()) @db.Uuid
  name                  String
  stageId               String                @db.Uuid
  displayOrder          Int                   @default(0)
  supportPhone          String?
  supportEmail          String?
  supportWhatsapp       String?
  createdAt             DateTime              @default(now())
  updatedAt             DateTime              @updatedAt
  stage                 Stage                 @relation(fields: [stageId], references: [id], onDelete: Cascade)
  units                 Unit[]
  books                 Book[]
  teacherGrades         TeacherGrade[]
  users                 User[]
  stories               Story[]
  finalReviews          FinalReview[]
  competitions          Competition[]          @relation("CompetitionGrade")
  liveSessions          LiveSession[]
  teacherAvailabilities TeacherAvailability[]

  @@index([stageId])
  @@index([displayOrder])
  @@map("grades")
}

model AcademicYear {
  id           String        @id @default(uuid()) @db.Uuid
  name         String        @unique
  isActive     Boolean       @default(true)
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  terms        Term[]
  units        Unit[]
  users        User[]
  stories      Story[]
  finalReviews FinalReview[]
  competitions Competition[] @relation("CompetitionAcademicYear")

  @@map("academic_years")
}

model Term {
  id             String        @id @default(uuid()) @db.Uuid
  name           String
  academicYearId String        @db.Uuid
  displayOrder   Int           @default(0)
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  academicYear   AcademicYear  @relation(fields: [academicYearId], references: [id], onDelete: Cascade)
  books          Book[]
  units          Unit[]
  users          User[]
  stories        Story[]
  finalReviews   FinalReview[]
  competitions   Competition[] @relation("CompetitionTerm")

  @@index([academicYearId])
  @@map("terms")
}

model Book {
  id        String   @id @default(uuid()) @db.Uuid
  title     String
  gradeId   String   @db.Uuid
  termId    String   @db.Uuid
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  grade     Grade    @relation(fields: [gradeId], references: [id], onDelete: Cascade)
  term      Term     @relation(fields: [termId], references: [id], onDelete: Cascade)
  units     Unit[]

  @@index([gradeId])
  @@index([termId])
  @@map("books")
}

model TeacherGrade {
  userId    String   @db.Uuid
  gradeId   String   @db.Uuid
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  grade     Grade    @relation(fields: [gradeId], references: [id], onDelete: Cascade)

  @@id([userId, gradeId])
  @@index([gradeId])
  @@map("teacher_grades")
}

model Unit {
  id                String        @id @default(uuid()) @db.Uuid
  title             String
  description       String?
  gradeId           String        @db.Uuid
  displayOrder      Int           @default(0)
  isPremium         Boolean       @default(false)
  lockedOverride    Boolean?
  published         Boolean       @default(false)
  academicYearId    String?       @db.Uuid
  termId            String?       @db.Uuid
  educationalSystem String?
  bookId            String?       @db.Uuid
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt
  lessons           Lesson[]
  grade             Grade         @relation(fields: [gradeId], references: [id], onDelete: Cascade)
  academicYear      AcademicYear? @relation(fields: [academicYearId], references: [id])
  term              Term?         @relation(fields: [termId], references: [id])
  book              Book?         @relation(fields: [bookId], references: [id])
  assessments       Assessment[]

  @@index([gradeId])
  @@index([displayOrder])
  @@index([academicYearId])
  @@index([termId])
  @@index([educationalSystem])
  @@index([bookId])
  @@map("units")
}

model Lesson {
  id                  String               @id @default(uuid()) @db.Uuid
  title               String
  unitId              String               @db.Uuid
  displayOrder        Int                  @default(0)
  estimatedDuration   Int                  @default(0)
  isPremium           Boolean              @default(false)
  lockedOverride      Boolean?
  published           Boolean              @default(false)
  isHidden            Boolean              @default(false)
  sequentialMode      Boolean              @default(true)
  homeworkEnabled     Boolean              @default(false)
  quizEnabled         Boolean              @default(false)
  passingScore        Int                  @default(70)
  maxAttempts         Int                  @default(3)
  xpReward            Int                  @default(100)
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
  homework            Homework?
  document            LessonDocument?
  progress            LessonProgress[]
  settings            LessonSettings?
  videos              LessonVideo[]
  vocabulary          LessonVocabulary[]
  vocabularySections  VocabularySection[]
  vocabularyRelations VocabularyRelation[]
  questionGroups      QuestionGroup[]
  questions           Question[]
  unit                Unit                 @relation(fields: [unitId], references: [id], onDelete: Cascade)
  quiz                Quiz?
  assessments         Assessment[]

  @@index([unitId])
  @@index([displayOrder])
  @@map("lessons")
}

model QuestionGroup {
  id           String     @id @default(uuid()) @db.Uuid
  lessonId     String     @db.Uuid
  title        String
  kind         String     @default("GENERAL")
  displayOrder Int        @default(0)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  deletedAt    DateTime?
  lesson       Lesson     @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  questions    Question[]

  @@index([lessonId])
  @@index([lessonId, displayOrder])
  @@map("question_groups")
}

model Question {
  id                  String                  @id @default(uuid()) @db.Uuid
  lessonId            String                  @db.Uuid
  groupId             String?                 @db.Uuid
  type                String
  prompt              String
  instruction         String?
  explanation         String?
  displayOrder        Int                     @default(0)
  config              Json?
  metadata            Json?
  createdAt           DateTime                @default(now())
  updatedAt           DateTime                @updatedAt
  deletedAt           DateTime?
  lesson              Lesson                  @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  group               QuestionGroup?          @relation(fields: [groupId], references: [id], onDelete: SetNull)
  options             QuestionOption[]
  hints               QuestionHint[]
  attachments         QuestionAttachment[]
  tagAssignments      QuestionTagAssignment[]
  assessmentQuestions AssessmentQuestion[]
  assessmentAnswers   AssessmentAnswer[]

  @@index([lessonId])
  @@index([lessonId, displayOrder])
  @@index([groupId])
  @@map("questions")
}

model QuestionOption {
  id           String   @id @default(uuid()) @db.Uuid
  questionId   String   @db.Uuid
  label        String
  text         String
  isCorrect    Boolean  @default(false)
  displayOrder Int      @default(0)
  createdAt    DateTime @default(now())
  question     Question @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@index([questionId])
  @@index([questionId, displayOrder])
  @@map("question_options")
}

model QuestionHint {
  id           String   @id @default(uuid()) @db.Uuid
  questionId   String   @db.Uuid
  text         String
  displayOrder Int      @default(0)
  createdAt    DateTime @default(now())
  question     Question @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@index([questionId])
  @@map("question_hints")
}

model QuestionAttachment {
  id           String   @id @default(uuid()) @db.Uuid
  questionId   String   @db.Uuid
  url          String
  mimeType     String
  name         String
  displayOrder Int      @default(0)
  createdAt    DateTime @default(now())
  question     Question @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@index([questionId])
  @@map("question_attachments")
}

model QuestionTag {
  id          String                  @id @default(uuid()) @db.Uuid
  name        String                  @unique
  createdAt   DateTime                @default(now())
  assignments QuestionTagAssignment[]

  @@map("question_tags")
}

model QuestionTagAssignment {
  questionId String      @db.Uuid
  tagId      String      @db.Uuid
  createdAt  DateTime    @default(now())
  question   Question    @relation(fields: [questionId], references: [id], onDelete: Cascade)
  tag        QuestionTag @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([questionId, tagId])
  @@index([tagId])
  @@map("question_tag_assignments")
}

model LessonSettings {
  id                   String   @id @default(uuid()) @db.Uuid
  lessonId             String   @unique @db.Uuid
  allowRetry           Boolean  @default(true)
  showAnswers          Boolean  @default(true)
  unlockNextOnComplete Boolean  @default(true)
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
  lesson               Lesson   @relation(fields: [lessonId], references: [id], onDelete: Cascade)

  @@map("lesson_settings")
}

model LessonDocument {
  id          String   @id @default(uuid()) @db.Uuid
  lessonId    String   @unique @db.Uuid
  fileName    String
  fileUrl     String
  mimeType    String   @default("application/pdf")
  fileSize    Int      @default(0)
  downloadable Boolean @default(true)
  createdAt   DateTime @default(now())
  lesson      Lesson   @relation(fields: [lessonId], references: [id], onDelete: Cascade)

  @@map("lesson_documents")
}

model LessonVideo {
  id                         String          @id @default(uuid()) @db.Uuid
  lessonId                   String          @db.Uuid
  title                      String
  /// @deprecated Use providerUrl and providerVideoId instead
  youtubeUrl                 String
  /// @deprecated Use providerVideoId instead
  youtubeId                  String
  providerName               String          @default("YOUTUBE")
  providerVideoId            String
  providerUrl                String
  duration                   Int             @default(0)
  displayOrder               Int             @default(0)
  enabled                    Boolean         @default(true)
  interactiveTimelineEnabled Boolean         @default(true)
  createdAt                  DateTime        @default(now())
  updatedAt                  DateTime        @updatedAt
  activities                 Activity[]
  lesson                     Lesson          @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  timelineEvents             TimelineEvent[]
  videoEvents                VideoEvent[]

  @@index([lessonId])
  @@index([displayOrder])
  @@map("lesson_videos")
}

model VideoEvent {
  id            String         @id @default(uuid()) @db.Uuid
  videoId       String         @db.Uuid
  timestamp     Int
  type          String
  title         String
  description   String         @default("")
  required      Boolean        @default(false)
  enabled       Boolean        @default(true)
  displayOrder  Int            @default(0)
  payload       Json           @default("{}")
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  video         LessonVideo    @relation(fields: [videoId], references: [id], onDelete: Cascade)
  videoQuestion VideoQuestion?

  @@index([videoId])
  @@index([videoId, timestamp])
  @@index([videoId, enabled])
  @@map("video_events")
}

model VideoQuestion {
  id           String                @id @default(uuid()) @db.Uuid
  videoEventId String                @unique @db.Uuid
  type         String
  title        String
  instructions String?
  displayOrder Int                   @default(0)
  metadata     Json                  @default("{}")
  createdAt    DateTime              @default(now())
  updatedAt    DateTime              @updatedAt
  videoEvent   VideoEvent            @relation(fields: [videoEventId], references: [id], onDelete: Cascade)
  options      VideoQuestionOption[]

  @@map("video_questions")
}

model VideoQuestionOption {
  id           String        @id @default(uuid()) @db.Uuid
  questionId   String        @db.Uuid
  text         String
  isCorrect    Boolean       @default(false)
  displayOrder Int           @default(0)
  metadata     Json          @default("{}")
  question     VideoQuestion @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@index([questionId])
  @@map("video_question_options")
}

model TimelineEvent {
  id        String      @id @default(uuid()) @db.Uuid
  videoId   String      @db.Uuid
  timestamp Int
  title     String?
  required  Boolean     @default(true)
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt
  video     LessonVideo @relation(fields: [videoId], references: [id], onDelete: Cascade)

  @@index([videoId])
  @@index([timestamp])
  @@map("timeline_events")
}

model Activity {
  id           String             @id @default(uuid()) @db.Uuid
  videoId      String             @db.Uuid
  type         ActivityType
  title        String
  instructions String?
  config       String?
  displayOrder Int                @default(0)
  required     Boolean            @default(true)
  createdAt    DateTime           @default(now())
  updatedAt    DateTime           @updatedAt
  video        LessonVideo        @relation(fields: [videoId], references: [id], onDelete: Cascade)
  progress     ActivityProgress[]
  questions    ActivityQuestion[]

  @@index([videoId])
  @@index([displayOrder])
  @@map("activities")
