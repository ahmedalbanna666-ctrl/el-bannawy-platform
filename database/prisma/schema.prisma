generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                      String                   @id @default(uuid()) @db.Uuid
  fullName                String
  englishName             String?
  email                   String?                  @unique
  mobileNumber            String?                  @unique
  parentMobile            String?
  passwordHash            String?
  googleId                String?                  @unique
  appleId                 String?                  @unique
  oauthProvider           String?
  role                    UserRole
  status                  AccountStatus            @default(PENDING_VERIFICATION)
  educationalSystem       String?
  educationalStage        String?
  grade                   String?
  academicTerm            String?
  governorate             String?
  school                  String?
  academicYearId          String?                  @db.Uuid
  termId                  String?                  @db.Uuid
  gradeId                 String?                  @db.Uuid
  createdAt               DateTime                 @default(now())
  updatedAt               DateTime                 @updatedAt
  deletedAt               DateTime?
  activityProgress        ActivityProgress[]
  attendance              AttendanceRecord[]
  coinWallet              CoinWallet?
  conversations           Conversation[]
  lessonProgress          LessonProgress[]
  loginHistory            LoginHistory[]
  notificationPreferences NotificationPreference?
  notifications           Notification[]
  passwordResets          PasswordReset[]
  payments                Payment[]
  quizAttempts            QuizAttempt[]
  refreshTokens           RefreshToken[]
  sessions                Session[]
  homeworkAttempts        StudentHomeworkAttempt[]
  achievements            UserAchievement[]
  videoProgress           VideoProgress[]
  xpTransactions          XPTransaction[]
  academicYear            AcademicYear?            @relation(fields: [academicYearId], references: [id])
  term                    Term?                    @relation(fields: [termId], references: [id])
  assignedGrade           Grade?                   @relation(fields: [gradeId], references: [id])
  teacherGrades           TeacherGrade[]
  auditLogs               AuditLog[]
  managedByTeacherId      String?                  @db.Uuid
  managedByTeacher        User?                    @relation("TeacherManagesStaff", fields: [managedByTeacherId], references: [id])
  managedStaff            User[]                   @relation("TeacherManagesStaff")
  permissionGrants        UserPermissionGrant[]    @relation("PermissionHolder")
  grantedPermissions      UserPermissionGrant[]    @relation("PermissionGrantor")

  @@index([mobileNumber])
  @@index([role])
  @@index([status])
  @@index([managedByTeacherId])
  @@map("users")
}

model Session {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @db.Uuid
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([token])
  @@map("sessions")
}

model RefreshToken {
  id        String    @id @default(uuid()) @db.Uuid
  userId    String    @db.Uuid
  token     String    @unique
  expiresAt DateTime
  createdAt DateTime  @default(now())
  revokedAt DateTime?
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([token])
  @@map("refresh_tokens")
}

model LoginHistory {
  id            String   @id @default(uuid()) @db.Uuid
  userId        String   @db.Uuid
  ipAddress     String?
  userAgent     String?
  success       Boolean
  failureReason String?
  createdAt     DateTime @default(now())
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([createdAt])
  @@map("login_history")
}

model PasswordReset {
  id               String    @id @default(uuid()) @db.Uuid
  userId           String    @db.Uuid
  verificationCode String
  expiresAt        DateTime
  usedAt           DateTime?
  createdAt        DateTime  @default(now())
  user             User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([verificationCode])
  @@map("password_resets")
}

model XPTransaction {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @db.Uuid
  amount    Int
  reason    String
  reference String?
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([createdAt])
  @@map("xp_transactions")
}

model CoinWallet {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @unique @db.Uuid
  balance   Int      @default(0)
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("coin_wallets")
}

model Payment {
  id              String    @id @default(uuid()) @db.Uuid
  userId          String    @db.Uuid
  productType     String
  productId       String
  amount          Int
  currency        String    @default("EGP")
  paymentMethod   String
  status          String    @default("PENDING")
  gatewayRef      String?
  gatewayResponse String?
  couponId        String?
  discount        Int       @default(0)
  createdAt       DateTime  @default(now())
  completedAt     DateTime?
  invoice         Invoice?
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([status])
  @@index([createdAt])
  @@map("payments")
}

model Invoice {
  id        String   @id @default(uuid()) @db.Uuid
  paymentId String   @unique @db.Uuid
  number    String   @unique
  createdAt DateTime @default(now())
  payment   Payment  @relation(fields: [paymentId], references: [id], onDelete: Cascade)

  @@map("invoices")
}

model Coupon {
  id                 String    @id @default(uuid()) @db.Uuid
  code               String    @unique
  discountType       String    @default("PERCENTAGE")
  discountValue      Int
  maxUses            Int?
  usedCount          Int       @default(0)
  expiresAt          DateTime?
  applicableProducts String?
  active             Boolean   @default(true)
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  @@map("coupons")
}

model UserAchievement {
  id          String   @id @default(uuid()) @db.Uuid
  userId      String   @db.Uuid
  type        String
  title       String
  description String?
  icon        String?
  earnedAt    DateTime @default(now())
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, type])
  @@index([userId])
  @@map("user_achievements")
}

model LessonProgress {
  id          String    @id @default(uuid()) @db.Uuid
  userId      String    @db.Uuid
  lessonId    String    @db.Uuid
  completed   Boolean   @default(false)
  progress    Float     @default(0)
  startedAt   DateTime  @default(now())
  completedAt DateTime?
  lesson      Lesson    @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, lessonId])
  @@index([userId])
  @@index([lessonId])
  @@map("lesson_progress")
}

model AttendanceRecord {
  id      String   @id @default(uuid()) @db.Uuid
  userId  String   @db.Uuid
  date    DateTime @default(now())
  present Boolean  @default(true)
  user    User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, date])
  @@index([userId])
  @@index([date])
  @@map("attendance_records")
}

model Stage {
  id           String   @id @default(uuid()) @db.Uuid
  name         String
  displayOrder Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  grades       Grade[]

  @@index([displayOrder])
  @@map("stages")
}

model Grade {
  id            String         @id @default(uuid()) @db.Uuid
  name          String
  stageId       String         @db.Uuid
  displayOrder  Int            @default(0)
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  stage         Stage          @relation(fields: [stageId], references: [id], onDelete: Cascade)
  units         Unit[]
  books         Book[]
  teacherGrades TeacherGrade[]
  users         User[]

  @@index([stageId])
  @@index([displayOrder])
  @@map("grades")
}

model AcademicYear {
  id        String   @id @default(uuid()) @db.Uuid
  name      String   @unique
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  terms     Term[]
  units     Unit[]
  users     User[]

  @@map("academic_years")
}

model Term {
  id             String       @id @default(uuid()) @db.Uuid
  name           String
  academicYearId String       @db.Uuid
  displayOrder   Int          @default(0)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  academicYear   AcademicYear @relation(fields: [academicYearId], references: [id], onDelete: Cascade)
  books          Book[]
  units          Unit[]
  users          User[]

  @@index([academicYearId])
  @@map("terms")
}

model Book {
  id        String   @id @default(uuid()) @db.Uuid
  title     String
  gradeId   String   @db.Uuid
  termId    String   @db.Uuid
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  grade     Grade    @relation(fields: [gradeId], references: [id], onDelete: Cascade)
  term      Term     @relation(fields: [termId], references: [id], onDelete: Cascade)
  units     Unit[]

  @@index([gradeId])
  @@index([termId])
  @@map("books")
}

model TeacherGrade {
  userId    String   @db.Uuid
  gradeId   String   @db.Uuid
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  grade     Grade    @relation(fields: [gradeId], references: [id], onDelete: Cascade)

  @@id([userId, gradeId])
  @@index([gradeId])
  @@map("teacher_grades")
}

model Unit {
  id                String        @id @default(uuid()) @db.Uuid
  title             String
  description       String?
  gradeId           String        @db.Uuid
  displayOrder      Int           @default(0)
  isPremium         Boolean       @default(false)
  published         Boolean       @default(true)
  academicYearId    String?       @db.Uuid
  termId            String?       @db.Uuid
  educationalSystem String?
  bookId            String?       @db.Uuid
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt
  lessons           Lesson[]
  grade             Grade         @relation(fields: [gradeId], references: [id], onDelete: Cascade)
  academicYear      AcademicYear? @relation(fields: [academicYearId], references: [id])
  term              Term?         @relation(fields: [termId], references: [id])
  book              Book?         @relation(fields: [bookId], references: [id])

  @@index([gradeId])
  @@index([displayOrder])
  @@index([academicYearId])
  @@index([termId])
  @@index([educationalSystem])
  @@index([bookId])
  @@map("units")
}

model Lesson {
  id                String             @id @default(uuid()) @db.Uuid
  title             String
  unitId            String             @db.Uuid
  displayOrder      Int                @default(0)
  estimatedDuration Int                @default(0)
  isPremium         Boolean            @default(false)
  published         Boolean            @default(true)
  isHidden          Boolean            @default(false)
  sequentialMode    Boolean            @default(true)
  homeworkEnabled   Boolean            @default(false)
  quizEnabled       Boolean            @default(false)
  passingScore      Int                @default(70)
  maxAttempts       Int                @default(3)
  xpReward          Int                @default(100)
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  homework          Homework?
  document          LessonDocument?
  progress          LessonProgress[]
  settings          LessonSettings?
  videos            LessonVideo[]
  vocabulary        LessonVocabulary[]
  unit              Unit               @relation(fields: [unitId], references: [id], onDelete: Cascade)
  quiz              Quiz?

  @@index([unitId])
  @@index([displayOrder])
  @@map("lessons")
}

model LessonSettings {
  id                   String   @id @default(uuid()) @db.Uuid
  lessonId             String   @unique @db.Uuid
  allowRetry           Boolean  @default(true)
  showAnswers          Boolean  @default(true)
  unlockNextOnComplete Boolean  @default(true)
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
  lesson               Lesson   @relation(fields: [lessonId], references: [id], onDelete: Cascade)

  @@map("lesson_settings")
}

model LessonDocument {
  id        String   @id @default(uuid()) @db.Uuid
  lessonId  String   @unique @db.Uuid
  fileName  String
  fileUrl   String
  fileSize  Int      @default(0)
  createdAt DateTime @default(now())
  lesson    Lesson   @relation(fields: [lessonId], references: [id], onDelete: Cascade)

  @@map("lesson_documents")
}

model LessonVideo {
  id                         String          @id @default(uuid()) @db.Uuid
  lessonId                   String          @db.Uuid
  title                      String
  youtubeUrl                 String
  youtubeId                  String
  duration                   Int             @default(0)
  displayOrder               Int             @default(0)
  enabled                    Boolean         @default(true)
  interactiveTimelineEnabled Boolean         @default(true)
  createdAt                  DateTime        @default(now())
  updatedAt                  DateTime        @updatedAt
  activities                 Activity[]
  lesson                     Lesson          @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  timelineEvents             TimelineEvent[]

  @@index([lessonId])
  @@index([displayOrder])
  @@map("lesson_videos")
}

model TimelineEvent {
  id        String      @id @default(uuid()) @db.Uuid
  videoId   String      @db.Uuid
  timestamp Int
  title     String?
  required  Boolean     @default(true)
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt
  video     LessonVideo @relation(fields: [videoId], references: [id], onDelete: Cascade)

  @@index([videoId])
  @@index([timestamp])
  @@map("timeline_events")
}

model Activity {
  id           String             @id @default(uuid()) @db.Uuid
  videoId      String             @db.Uuid
  type         ActivityType
  title        String
  instructions String?
  config       String?
  displayOrder Int                @default(0)
  required     Boolean            @default(true)
  createdAt    DateTime           @default(now())
  updatedAt    DateTime           @updatedAt
  video        LessonVideo        @relation(fields: [videoId], references: [id], onDelete: Cascade)
  progress     ActivityProgress[]
  questions    ActivityQuestion[]

  @@index([videoId])
  @@index([displayOrder])
  @@map("activities")
}

model ActivityQuestion {
  id            String   @id @default(uuid()) @db.Uuid
  activityId    String   @db.Uuid
  question      String
  options       String?
  correctAnswer String?
  displayOrder  Int      @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  activity      Activity @relation(fields: [activityId], references: [id], onDelete: Cascade)

  @@index([activityId])
  @@map("activity_questions")
}

model LessonVocabulary {
  id           String   @id @default(uuid()) @db.Uuid
  lessonId     String   @db.Uuid
  word         String
  translation  String
  definition   String?
  example      String?
  displayOrder Int      @default(0)
  createdAt    DateTime @default(now())
  lesson       Lesson   @relation(fields: [lessonId], references: [id], onDelete: Cascade)

  @@index([lessonId])
  @@map("lesson_vocabulary")
}

model Homework {
  id           String                   @id @default(uuid()) @db.Uuid
  lessonId     String                   @unique @db.Uuid
  title        String                   @default("Homework")
  instructions String?
  passingScore Int                      @default(70)
  maxAttempts  Int                      @default(3)
  xpReward     Int                      @default(50)
  published    Boolean                  @default(true)
  allowRetry   Boolean                  @default(true)
  showAnswers  Boolean                  @default(true)
  createdAt    DateTime                 @default(now())
  updatedAt    DateTime                 @updatedAt
  deletedAt    DateTime?
  lesson       Lesson                   @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  questions    HomeworkQuestion[]
  attempts     StudentHomeworkAttempt[]

  @@map("homework")
}

model HomeworkQuestion {
  id            String           @id @default(uuid()) @db.Uuid
  homeworkId    String           @db.Uuid
  type          String           @default("MULTIPLE_CHOICE")
  question      String
  options       String?
  correctAnswer String?
  explanation   String?
  displayOrder  Int              @default(0)
  createdAt     DateTime         @default(now())
  answers       HomeworkAnswer[]
  homework      Homework         @relation(fields: [homeworkId], references: [id], onDelete: Cascade)

  @@index([homeworkId])
  @@map("homework_questions")
}

model Quiz {
  id           String         @id @default(uuid()) @db.Uuid
  lessonId     String         @unique @db.Uuid
  title        String         @default("End Lesson Assessment")
  instructions String?
  passingScore Int            @default(70)
  maxAttempts  Int            @default(3)
  xpReward     Int            @default(100)
  published    Boolean        @default(true)
  allowRetry   Boolean        @default(true)
  showAnswers  Boolean        @default(true)
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt
  deletedAt    DateTime?
  attempts     QuizAttempt[]
  questions    QuizQuestion[]
  lesson       Lesson         @relation(fields: [lessonId], references: [id], onDelete: Cascade)

  @@map("quizzes")
}

model QuizQuestion {
  id            String       @id @default(uuid()) @db.Uuid
  quizId        String       @db.Uuid
  type          String       @default("MULTIPLE_CHOICE")
  question      String
  options       String?
  correctAnswer String?
  explanation   String?
  displayOrder  Int          @default(0)
  createdAt     DateTime     @default(now())
  answers       QuizAnswer[]
  quiz          Quiz         @relation(fields: [quizId], references: [id], onDelete: Cascade)

  @@index([quizId])
  @@map("quiz_questions")
}

model VideoProgress {
  id             String    @id @default(uuid()) @db.Uuid
  userId         String    @db.Uuid
  videoId        String    @db.Uuid
  watchedSeconds Int       @default(0)
  completed      Boolean   @default(false)
  lastPosition   Int       @default(0)
  startedAt      DateTime  @default(now())
  completedAt    DateTime?
  updatedAt      DateTime  @updatedAt
  user           User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, videoId])
  @@index([userId])
  @@index([videoId])
  @@map("video_progress")
}

model ActivityProgress {
  id          String    @id @default(uuid()) @db.Uuid
  userId      String    @db.Uuid
  activityId  String    @db.Uuid
  completed   Boolean   @default(false)
  score       Int?
  response    String?
  startedAt   DateTime  @default(now())
  completedAt DateTime?
  activity    Activity  @relation(fields: [activityId], references: [id], onDelete: Cascade)
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, activityId])
  @@index([userId])
  @@index([activityId])
  @@map("activity_progress")
}

model StudentHomeworkAttempt {
  id          String           @id @default(uuid()) @db.Uuid
  userId      String           @db.Uuid
  homeworkId  String           @db.Uuid
  score       Int?
  passed      Boolean?
  submitted   Boolean          @default(false)
  attemptNum  Int              @default(1)
  startedAt   DateTime         @default(now())
  submittedAt DateTime?
  answers     HomeworkAnswer[]
  homework    Homework         @relation(fields: [homeworkId], references: [id], onDelete: Cascade)
  user        User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([homeworkId])
  @@map("student_homework_attempts")
}

model HomeworkAnswer {
  id         String                 @id @default(uuid()) @db.Uuid
  attemptId  String                 @db.Uuid
  questionId String                 @db.Uuid
  answer     String?
  isCorrect  Boolean?
  createdAt  DateTime               @default(now())
  attempt    StudentHomeworkAttempt @relation(fields: [attemptId], references: [id], onDelete: Cascade)
  question   HomeworkQuestion       @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@unique([attemptId, questionId])
  @@index([attemptId])
  @@index([questionId])
  @@map("homework_answers")
}

model QuizAttempt {
  id          String       @id @default(uuid()) @db.Uuid
  userId      String       @db.Uuid
  quizId      String       @db.Uuid
  score       Int?
  passed      Boolean?
  submitted   Boolean      @default(false)
  attemptNum  Int          @default(1)
  startedAt   DateTime     @default(now())
  submittedAt DateTime?
  answers     QuizAnswer[]
  quiz        Quiz         @relation(fields: [quizId], references: [id], onDelete: Cascade)
  user        User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([quizId])
  @@map("quiz_attempts")
}

model QuizAnswer {
  id         String       @id @default(uuid()) @db.Uuid
  attemptId  String       @db.Uuid
  questionId String       @db.Uuid
  answer     String?
  isCorrect  Boolean?
  createdAt  DateTime     @default(now())
  attempt    QuizAttempt  @relation(fields: [attemptId], references: [id], onDelete: Cascade)
  question   QuizQuestion @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@unique([attemptId, questionId])
  @@index([attemptId])
  @@index([questionId])
  @@map("quiz_answers")
}

model Notification {
  id        String    @id @default(uuid()) @db.Uuid
  userId    String    @db.Uuid
  title     String
  message   String
  type      String
  priority  String    @default("MEDIUM")
  channel   String    @default("IN_APP")
  isRead    Boolean   @default(false)
  readAt    DateTime?
  deletedAt DateTime?
  createdAt DateTime  @default(now())
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([isRead])
  @@index([createdAt])
  @@map("notifications")
}

model NotificationPreference {
  id                       String   @id @default(uuid()) @db.Uuid
  userId                   String   @unique @db.Uuid
  lessonReminders          Boolean  @default(true)
  homeworkReminders        Boolean  @default(true)
  liveSessionReminders     Boolean  @default(true)
  achievementNotifications Boolean  @default(true)
  motivationalMessages     Boolean  @default(true)
  studyTips                Boolean  @default(true)
  teacherAnnouncements     Boolean  @default(true)
  updatedAt                DateTime @updatedAt
  user                     User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("notification_preferences")
}

model Conversation {
  id        String                @id @default(uuid()) @db.Uuid
  userId    String                @db.Uuid
  title     String                @default("New Conversation")
  deletedAt DateTime?
  createdAt DateTime              @default(now())
  updatedAt DateTime              @updatedAt
  messages  ConversationMessage[]
  user      User                  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("conversations")
}

model ConversationMessage {
  id             String       @id @default(uuid()) @db.Uuid
  conversationId String       @db.Uuid
  role           String
  content        String
  createdAt      DateTime     @default(now())
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId])
  @@map("conversation_messages")
}

model SystemSetting {
  id        String   @id @default(uuid()) @db.Uuid
  key       String   @unique
  value     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("system_settings")
}

model AuditLog {
  id        String   @id @default(uuid()) @db.Uuid
  actorId   String   @db.Uuid
  action    String
  entity    String
  entityId  String?
  details   String?
  ipAddress String?
  createdAt DateTime @default(now())
  actor     User     @relation(fields: [actorId], references: [id])

  @@index([actorId])
  @@index([entity])
  @@index([entityId])
  @@index([createdAt])
  @@map("audit_logs")
}

model UserPermissionGrant {
  id              String   @id @default(uuid()) @db.Uuid
  userId          String   @db.Uuid
  permission      String
  grantedByUserId String   @db.Uuid
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  user            User     @relation("PermissionHolder", fields: [userId], references: [id])
  grantedBy       User     @relation("PermissionGrantor", fields: [grantedByUserId], references: [id])

  @@unique([userId, permission])
  @@index([userId])
  @@index([grantedByUserId])
  @@map("user_permission_grants")
}

enum UserRole {
  STUDENT
  TEACHER
  STAFF
  SECRETARY
  SUPPORT
  ADMINISTRATOR
}

enum AccountStatus {
  ACTIVE
  PENDING_VERIFICATION
