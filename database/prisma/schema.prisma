enum ScoringType {
  AUTOMATIC
  MANUAL
  MIXED

  @@map("scoring_type")
}

model LiveSession {
  id              String            @id @default(uuid()) @db.Uuid
  title           String
  teacherId       String            @db.Uuid
  gradeId             String?           @db.Uuid
  groupId             String?           @db.Uuid
  availabilitySlotId  String?           @db.Uuid
  date                DateTime
  startTime       DateTime
  endTime         DateTime
  durationMinutes Int               @default(60)
  maxStudents     Int?
  availableSeats  Int?
  status          LiveSessionStatus @default(DRAFT)
  type            LiveSessionType   @default(PRIVATE)
  meetingUrl        String?
  meetingPassword   String?
  meetingProvider   MeetingProvider   @default(EXTERNAL_URL)
  notes             String?
  publishedAt       DateTime?
  scheduledAt       DateTime?
  openedAt          DateTime?
  liveAt            DateTime?
  completedAt       DateTime?
  cancelledAt       DateTime?
  cancelReason      String?
  archivedAt        DateTime?
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt
  deletedAt         DateTime?

  teacher              User                 @relation("LiveSessionsAsTeacher", fields: [teacherId], references: [id])
  grade                Grade?               @relation(fields: [gradeId], references: [id])
  availabilitySlot     TeacherAvailability? @relation(fields: [availabilitySlotId], references: [id])
  bookings             LiveBooking[]
  attendance           LiveAttendance[]
  announcements        LiveAnnouncement[]
  controlLogs          LiveSessionControlLog[]

  @@index([teacherId])
  @@index([gradeId])
  @@index([status])
  @@index([date])
  @@index([teacherId, date])
  @@map("live_sessions")
}

model LiveAnnouncement {
  id          String   @id @default(uuid()) @db.Uuid
  sessionId   String   @db.Uuid
  senderId    String   @db.Uuid
  message     String
  type        String   @default("INFO")
  pinned      Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  session LiveSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  sender  User        @relation("LiveAnnouncementSender", fields: [senderId], references: [id])

  @@index([sessionId])
  @@index([sessionId, createdAt])
  @@map("live_announcements")
}

model LiveSessionControlLog {
  id          String   @id @default(uuid()) @db.Uuid
  sessionId   String   @db.Uuid
  action      String
  actorId     String   @db.Uuid
  details     String?
  createdAt   DateTime @default(now())

  session LiveSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  actor   User        @relation("LiveSessionControlActor", fields: [actorId], references: [id])

  @@index([sessionId])
  @@index([sessionId, createdAt])
  @@map("live_session_control_logs")
}

model LiveBooking {
  id                    String            @id @default(uuid()) @db.Uuid
  sessionId             String            @db.Uuid
  studentId             String            @db.Uuid
  subscriptionId        String?           @db.Uuid
  status                LiveBookingStatus @default(CONFIRMED)
  rescheduleRequestedAt DateTime?
  rescheduleReason      String?
  cancelledAt           DateTime?
  cancelReason          String?
  createdAt             DateTime          @default(now())
  updatedAt             DateTime          @updatedAt

  session      LiveSession       @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  student      User              @relation("LiveBookingStudent", fields: [studentId], references: [id])
  subscription LiveSubscription? @relation(fields: [subscriptionId], references: [id])

  @@unique([sessionId, studentId])
  @@index([sessionId])
  @@index([studentId])
  @@index([studentId, status])
  @@map("live_bookings")
}

model LiveSubscription {
  id                  String                 @id @default(uuid()) @db.Uuid
  userId              String                 @db.Uuid
  type                LiveSubscriptionType
  packageLabel        String                 @default("4")
  packageSessionCount Int                    @default(4)
  status              LiveSubscriptionStatus @default(ACTIVE)
  teacherId           String?                @db.Uuid
  groupId             String?                @db.Uuid
  sessionsTotal       Int                    @default(0)
  sessionsUsed        Int                    @default(0)
  currentPeriodStart  DateTime
  currentPeriodEnd    DateTime
  nextBillingDate     DateTime?
  autoRenew           Boolean                @default(true)
  price               Int                    @default(0)
  cancelledAt         DateTime?
  cancelReason        String?
  suspendedAt         DateTime?
  createdAt           DateTime               @default(now())
  updatedAt           DateTime               @updatedAt
  deletedAt           DateTime?

  user     User          @relation("LiveSubscriptionHolder", fields: [userId], references: [id])
  teacher  User?         @relation("LiveSubscriptionTeacher", fields: [teacherId], references: [id])
  bookings LiveBooking[]

  @@index([userId])
  @@index([userId, status])
  @@index([teacherId])
  @@map("live_subscriptions")
}

model LiveAttendance {
  id              String               @id @default(uuid()) @db.Uuid
  sessionId       String               @db.Uuid
  studentId       String               @db.Uuid
  status          LiveAttendanceStatus
  joinedAt        DateTime?
  leftAt          DateTime?
  durationMinutes Int?
  markedBy        String               @default("AUTO")
  markedById      String?              @db.Uuid
  notes           String?
  createdAt       DateTime             @default(now())
  updatedAt       DateTime             @updatedAt

  session LiveSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  student User        @relation("LiveAttendanceStudent", fields: [studentId], references: [id])
  marker  User?       @relation("LiveAttendanceMarker", fields: [markedById], references: [id])

  @@unique([sessionId, studentId])
  @@index([sessionId])
  @@index([studentId])
  @@map("live_attendance")
}

model TeacherAvailability {
  id            String    @id @default(uuid()) @db.Uuid
  teacherId     String    @db.Uuid
  dayOfWeek     Int
  startTime     DateTime
  endTime       DateTime
  gradeId       String?   @db.Uuid
  maxStudents   Int             @default(1)
  type          LiveSessionType @default(PRIVATE)
  isRecurring   Boolean         @default(true)
  effectiveFrom DateTime?
  effectiveTo   DateTime?
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
  deletedAt     DateTime?

  teacher   User         @relation("TeacherAvailabilityTeacher", fields: [teacherId], references: [id])
  grade     Grade?       @relation(fields: [gradeId], references: [id])
  sessions  LiveSession[]

  @@index([teacherId])
  @@index([teacherId, dayOfWeek])
  @@map("teacher_availability")
}

model TeacherDateBlock {
  id          String    @id @default(uuid()) @db.Uuid
  teacherId   String    @db.Uuid
  blockedDate DateTime
  reason      String?
  createdAt   DateTime  @default(now())
  deletedAt   DateTime?

  teacher User @relation("TeacherDateBlockTeacher", fields: [teacherId], references: [id])

  @@unique([teacherId, blockedDate])
  @@index([teacherId])
  @@map("teacher_date_blocks")
}

model TeacherLiveSettings {
  id                String          @id @default(uuid()) @db.Uuid
  teacherId         String          @unique @db.Uuid
  defaultMeetingUrl String?
  meetingPassword   String?
  meetingProvider   MeetingProvider @default(EXTERNAL_URL)
  allowOverride     Boolean         @default(true)
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt

  teacher User @relation(fields: [teacherId], references: [id], onDelete: Cascade)

  @@map("teacher_live_settings")
}

model SupportTicket {
  id              String            @id @default(uuid()) @db.Uuid
  userId          String            @db.Uuid
  userRole        String
  category        String            @default("GENERAL")
  priority        String            @default("MEDIUM")
  status          String            @default("OPEN")
  subject         String
  description     String
  assignedAgentId String?           @db.Uuid
  resolution      String?
  resolvedAt      DateTime?
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt

  user        User            @relation("SupportTicketCreator", fields: [userId], references: [id], onDelete: Cascade)
  assignedAgent User?          @relation("SupportTicketAgent", fields: [assignedAgentId], references: [id])
  messages    SupportMessage[]

  @@index([userId])
  @@index([status])
  @@index([assignedAgentId])
  @@map("support_tickets")
}

model SupportMessage {
  id        String   @id @default(uuid()) @db.Uuid
  ticketId  String   @db.Uuid
  senderId  String   @db.Uuid
  senderRole String
  body      String
  internal  Boolean  @default(false)
  createdAt DateTime @default(now())

  ticket SupportTicket @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  sender User        @relation("SupportMessageSender", fields: [senderId], references: [id], onDelete: Cascade)

  @@index([ticketId])
  @@map("support_messages")
}
