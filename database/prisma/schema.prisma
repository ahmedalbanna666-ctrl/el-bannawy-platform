  section         FinalReviewSection @relation("FinalReviewSectionVideoSection", fields: [finalReviewSectionId], references: [id], onDelete: Cascade)

  @@index([finalReviewSectionId])
  @@index([displayOrder])
  @@map("final_review_section_videos")
}

model FinalReviewSectionVocab {
  id           String           @id @default(uuid()) @db.Uuid
  finalReviewSectionId String   @db.Uuid
  word         String
  translation  String
  definition   String?
  example      String?
  partOfSpeech String?
  displayOrder Int              @default(0)
  createdAt    DateTime         @default(now())
  section      FinalReviewSection @relation("FinalReviewSectionVocabSection", fields: [finalReviewSectionId], references: [id], onDelete: Cascade)

  @@index([finalReviewSectionId])
  @@map("final_review_section_vocab")
}

model FinalReviewSectionQuestion {
  id           String           @id @default(uuid()) @db.Uuid
  finalReviewSectionId String   @db.Uuid
  type         String           @default("MULTIPLE_CHOICE")
  question     String
  explanation  String?
  displayOrder Int              @default(0)
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt
  section      FinalReviewSection @relation("FinalReviewSectionQuestionSection", fields: [finalReviewSectionId], references: [id], onDelete: Cascade)
  options      FinalReviewSectionQuestionOption[]

  @@index([finalReviewSectionId])
  @@index([displayOrder])
  @@map("final_review_section_questions")
}

model FinalReviewSectionQuestionOption {
  id         String                    @id @default(uuid()) @db.Uuid
  questionId String                    @db.Uuid
  text       String
  isCorrect  Boolean                   @default(false)
  displayOrder Int                     @default(0)
  question   FinalReviewSectionQuestion @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@index([questionId])
  @@map("final_review_section_question_options")
}

model Competition {
  id              String   @id @default(uuid()) @db.Uuid
  title           String
  description     String?
  mode            String   @default("QUIZ")
  gradeId         String   @db.Uuid
  academicYearId  String   @db.Uuid
  termId          String   @db.Uuid
  createdById     String   @db.Uuid
  status          String   @default("DRAFT")
  visibility      String   @default("GRADE")
  startsAt        DateTime?
  endsAt          DateTime?
  timeLimitMinutes Int?
  xpReward        Int      @default(0)
  coinReward      Int      @default(0)
  questions       Json?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  createdBy       User     @relation("CompetitionCreator", fields: [createdById], references: [id])
  grade           Grade    @relation("CompetitionGrade", fields: [gradeId], references: [id])
  academicYear    AcademicYear @relation("CompetitionAcademicYear", fields: [academicYearId], references: [id])
  term            Term     @relation("CompetitionTerm", fields: [termId], references: [id])
  participants    CompetitionParticipant[]

  @@index([gradeId])
  @@index([createdById])
  @@index([status])
  @@map("competitions")
}

model CompetitionParticipant {
  id            String    @id @default(uuid()) @db.Uuid
  competitionId String    @db.Uuid
  studentId     String    @db.Uuid
  status        String    @default("INVITED")
  invitedBy     String?   @db.Uuid
  joinedAt      DateTime?
  submittedAt   DateTime?
  score         Int       @default(0)
  xpGained      Int       @default(0)
  correctCount  Int       @default(0)
  durationSeconds Int?
  answers       Json?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  competition   Competition @relation(fields: [competitionId], references: [id], onDelete: Cascade)
  student       User       @relation("CompetitionParticipantStudent", fields: [studentId], references: [id])

  @@unique([competitionId, studentId])
  @@index([competitionId])
  @@index([studentId])
  @@index([status])
  @@map("competition_participants")
}

enum UserRole {
  STUDENT
  TEACHER
  STAFF
  SECRETARY
  SUPPORT
  ADMINISTRATOR
}

