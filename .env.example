# Database
DATABASE_URL="postgresql://elbannawy:elbannawy_dev@localhost:5432/elbannawy_platform"

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379

# JWT
JWT_SECRET=change-me-to-a-secure-random-string
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# OAuth – Google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:4000/api/v1/auth/google/callback

# OAuth – Apple
APPLE_CLIENT_ID=
APPLE_TEAM_ID=
APPLE_KEY_ID=
APPLE_PRIVATE_KEY=
APPLE_CALLBACK_URL=http://localhost:4000/api/v1/auth/apple/callback

# Frontend URL (for OAuth redirects)
FRONTEND_URL=http://localhost:3000

# AI (Optional - leave empty to use rule-based fallback)
AI_API_KEY=
AI_ENDPOINT=https://api.openai.com/v1/chat/completions
AI_MODEL=gpt-4o-mini

# Firebase (Optional - get from Firebase Console)
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_DATABASE_URL=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# Payments – Public base URL used in gateway redirect/callback links
PUBLIC_BASE_URL=http://localhost:4000

# Payments – Webhook signature secret (POST /api/v1/webhooks/payments)
# REQUIRED. Application will not start without it.
PAYMENT_WEBHOOK_SECRET=change-me-to-a-secure-random-string

# Payments – Simulation mode HMAC key (for dev/test payment flows)
# Required if using simulated gateways. Set a random 32+ char string.
SIMULATION_HMAC_KEY=dev-simulation-key-change-me

# Payments – Paymob (leave empty to use simulation mode)
PAYMOB_API_KEY=
PAYMOB_HMAC_SECRET=
PAYMOB_MERCHANT_ID=
PAYMOB_BASE_URL=https://accept.paymob.com
PAYMOB_INTEGRATION_IDS=

# Payments – Fawry (leave empty to use simulation mode)
FAWRY_MERCHANT_CODE=
FAWRY_SECURITY_KEY=
FAWRY_BASE_URL=https://developer.fawrystaging.com

# Payments – Instapay (leave empty to use simulation mode)
INSTAPAY_API_KEY=
INSTAPAY_BASE_URL=https://ipn.eg

# Payments – Vodafone Cash (leave empty to use simulation mode)
VODAFONE_CASH_MERCHANT_ID=
VODAFONE_CASH_SECRET=
VODAFONE_CASH_BASE_URL=

# Payments – Orange Cash (leave empty to use simulation mode)
ORANGE_CASH_MERCHANT_ID=
ORANGE_CASH_SECRET=
ORANGE_CASH_BASE_URL=

# Payments – Etisalat Cash (leave empty to use simulation mode)
ETISALAT_CASH_MERCHANT_ID=
ETISALAT_CASH_SECRET=
ETISALAT_CASH_BASE_URL=

