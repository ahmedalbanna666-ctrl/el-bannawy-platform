{
  "compilerOptions": {
    "module": "commonjs",
    "declaration": true,
    "removeComments": true,
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "allowSyntheticDefaultImports": true,
    "target": "ES2021",
    "sourceMap": true,
    "outDir": "./dist",
    "baseUrl": "./",
    "incremental": true,
    "skipLibCheck": true,
    "strict": true,
    "noImplicitAny": true,
    "strictBindCallApply": true,
    "forceConsistentCasingInFileNames": true,
    "noFallthroughCasesInSwitch": true,
    "paths": {
      "@el-bannawy/database": ["../../database"],
      "@el-bannawy/database/*": ["../../database/*"],
      "@el-bannawy/shared": ["../../packages/shared/dist"],
      "@el-bannawy/shared/*": ["../../packages/shared/dist/*"]
    }
  },
  "include": ["src/**/*", "test/**/*"]
}
